{
  "compilerOptions": {
    "allowJs": false,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "firefox-webext-browser"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.mjs"]
}
