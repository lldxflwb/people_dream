{
  "manifest_version": 3,
  "name": "People Dream Demo",
  "version": "0.1.0",
  "description": "Capture browser pages and send them to localhost for dream reporting.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "http://127.0.0.1:9095/*",
        "http://localhost:9095/*"
      ],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
